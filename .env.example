# Shared
SCION_ENV=development

# API
SCION_API_HOST=0.0.0.0
SCION_API_PORT=8000
SCION_API_PREFIX=/api
SCION_CORS_ORIGINS=http://localhost:3000
SCION_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/scion
SCION_LOG_LEVEL=INFO
SCION_SLOW_OPERATION_MS=250
SCION_EXPORT_MAX_ROWS=500
SCION_BUSY_RETRY_AFTER_SECONDS=5
SCION_EXPORT_SLOT_LIMIT=1
SCION_ANALYTICS_SLOT_LIMIT=4
SCION_SKIP_STARTUP_CHECKS=false

# Web
SCION_WEB_HOST=127.0.0.1
SCION_WEB_PORT=3000
SCION_API_BASE_URL=http://127.0.0.1:8000/api
SCION_API_TIMEOUT_MS=5000
NEXT_PUBLIC_SCION_API_BASE_URL=http://localhost:8000/api
NEXT_PUBLIC_SCION_API_TIMEOUT_MS=5000
